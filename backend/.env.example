# Cloudstream Web backend configuration — all optional, with sensible defaults.
# Copy to .env and adjust, or pass as environment variables to the container.

# Listen port and host
PORT=8080
HOST=0.0.0.0

# Persistent data directory (extension state + user library)
CLOUDSTREAM_WEB_DATA=data

# Auth: if AUTH_PASSWORD is empty, access is OPEN (dev / trusted LAN only).
# Set it to protect the instance. AUTH_SECRET signs the session token: changing it
# invalidates existing cookies (forced logout for everyone).
AUTH_PASSWORD=
AUTH_SECRET=cloudstream-web-default-secret-change-me

# CORS: empty = same-origin (FE served by Ktor in prod, Vite proxy in dev). Comma-separated
# list of extra hosts if the FE is served from a different origin.
CORS_HOSTS=

# Per-provider timeout for the aggregated search (ms)
SEARCH_TIMEOUT_MS=15000

# Directory of the static frontend build to serve (set inside the container).
# In dev leave it empty and use the Vite server.
FRONTEND_DIR=

# Log format: "text" readable (default, dev) or "json" structured (prod).
LOG_FORMAT=text
